        "level": 3,
        "title": "Recent_Activity",
        "text": "Field Value Variable ID INST_025 Definition Recent DPI-related activities, projects, statements (last 12-24 months) Format Text Data Collection Guidance Document recent activities with brief description and date/timeframe. Format: 'Activity description - Month Year; Another activity - Month Year'. Check press releases, annual reports, news coverage, project announcements.",
        "path": [],
        "tags": []
