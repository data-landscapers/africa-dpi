    "content": "<h1 id=\"govtech-maturity-index-metadata\">GovTech Maturity Index metadata<a class=\"headerlink\" href=\"#govtech-maturity-index-metadata\" title=\"Permanent link\">&para;</a></h1>\n<p>Metadata for a selection of performance indicators from the World Bank GovTech Maturity Index. 2025. Source: <a href=\"https://datacatalog.worldbank.org/search/dataset/0037889/govtech-dataset\">https://datacatalog.worldbank.org/search/dataset/0037889/govtech-dataset</a></p>\n<h3 id=\"shared-cloud-platform\">Shared cloud platform<a class=\"headerlink\" href=\"#shared-cloud-platform\" title=\"Permanent link\">&para;</a></h3>\n<table>\n<thead>\n<tr>\n<th>Field</th>\n<th>Value</th>\n</tr>\n</thead>\n<tbody>\n<tr>\n<td>Chapter</td>\n<td>GovTech Maturity</td>\n</tr>\n<tr>\n<td>Variable Id</td>\n<td>govtech-cloud-1</td>\n</tr>\n<tr>\n<td>Definition</td>\n<td>Is there a shared cloud platform available for all government entities?</td>\n</tr>\n<tr>\n<td>Format</td>\n<td>0=Unknown/n.a;1=No;2=Only cloud strategy/policy (no platform yet);3=Yes (platform in use)</td>\n</tr>\n<tr>\n<td>Other Metadata</td>\n<td></td>\n</tr>\n</tbody>\n</table>\n<h3 id=\"cloud-platform-type\">Cloud platform type<a class=\"headerlink\" href=\"#cloud-platform-type\" title=\"Permanent link\">&para;</a></h3>\n<table>\n<thead>\n<tr>\n<th>Field</th>\n<th>Value</th>\n</tr>\n</thead>\n<tbody>\n<tr>\n<td>Chapter</td>\n<td>GovTech Maturity</td>\n</tr>\n<tr>\n<td>Variable Id</td>\n<td>govtech-cloud-1.4</td>\n</tr>\n<tr>\n<td>Definition</td>\n<td>Type of cloud platform established</td>\n</tr>\n<tr>\n<td>Format</td>\n<td>0=Unkown/n.a.;1=Public (Commercial);2=Private (Government);3=Hybrid</td>\n</tr>\n<tr>\n<td>Other Metadata</td>\n<td>Type of cloud &gt; Public: Commercial operators; outside/in country; Private: Operated by government entities; on-premise, 3= Hybrid (combination of public \\&amp; private)</td>\n</tr>\n</tbody>\n</table>\n<h3 id=\"hosting-policy\">Hosting policy<a class=\"headerlink\" href=\"#hosting-policy\" title=\"Permanent link\">&para;</a></h3>\n<table>\n<thead>\n<tr>\n<th>Field</th>\n<th>Value</th>\n</tr>\n</thead>\n<tbody>\n<tr>\n<td>Chapter</td>\n<td>GovTech Maturity</td>\n</tr>\n<tr>\n<td>Variable Id</td>\n<td>govtech-cloud-1.6</td>\n</tr>\n<tr>\n<td>Definition</td>\n<td>Government Cloud data hosting policy?</td>\n</tr>\n<tr>\n<td>Format</td>\n<td>0=Unknown/n.a;1=No policy / Unkown/n.a.;2=Keeping data inside the country;3=Keeping data outside the country;4=Hybrid (inside + outside)</td>\n</tr>\n<tr>\n<td>Other Metadata</td>\n<td></td>\n</tr>\n</tbody>\n</table>\n<h3 id=\"service-provided\">Service provided<a class=\"headerlink\" href=\"#service-provided\" title=\"Permanent link\">&para;</a></h3>\n<table>\n<thead>\n<tr>\n<th>Field</th>\n<th>Value</th>\n</tr>\n</thead>\n<tbody>\n<tr>\n<td>Chapter</td>\n<td>GovTech Maturity</td>\n</tr>\n<tr>\n<td>Variable Id</td>\n<td>govtech-cloud-1.7</td>\n</tr>\n<tr>\n<td>Definition</td>\n<td>Cloud services provided</td>\n</tr>\n<tr>\n<td>Format</td>\n<td>0=Unkown/n.a.;1=SaaS;2=PaaS;3=IaaS;4=XaaS</td>\n</tr>\n<tr>\n<td>Other Metadata</td>\n<td>Cloud services &gt; SaaS: Software as a Service; PaaS: Platform as a Service; IaaS: Infrastructure as a Service; XaaS: Anything as a Service</td>\n</tr>\n</tbody>\n</table>\n<h3 id=\"single-shared-platform\">Single shared platform<a class=\"headerlink\" href=\"#single-shared-platform\" title=\"Permanent link\">&para;</a></h3>\n<table>\n<thead>\n<tr>\n<th>Field</th>\n<th>Value</th>\n</tr>\n</thead>\n<tbody>\n<tr>\n<td>Chapter</td>\n<td>GovTech Maturity</td>\n</tr>\n<tr>\n<td>Variable Id</td>\n<td>govtech-cloud-1.8</td>\n</tr>\n<tr>\n<td>Definition</td>\n<td>Is there one shared Government Cloud platform or several?</td>\n</tr>\n<tr>\n<td>Format</td>\n<td>0=Unkown/n.a.;1=Several cloud platforms (Central/Local levels);2=One shared cloud platform</td>\n</tr>\n<tr>\n<td>Other Metadata</td>\n<td></td>\n</tr>\n</tbody>\n</table>\n<h3 id=\"transparency\">Transparency<a class=\"headerlink\" href=\"#transparency\" title=\"Permanent link\">&para;</a></h3>\n<table>\n<thead>\n<tr>\n<th>Field</th>\n<th>Value</th>\n</tr>\n</thead>\n<tbody>\n<tr>\n<td>Chapter</td>\n<td>GovTech Maturity</td>\n</tr>\n<tr>\n<td>Variable Id</td>\n<td>govtech-cloud-1.9</td>\n</tr>\n<tr>\n<td>Definition</td>\n<td>Monitoring \\&amp; publishing of cloud usage, security, savings, etc.?</td>\n</tr>\n<tr>\n<td>Format</td>\n<td>0=Unknown/n.a;1=No;2=Yes (internal;not published); 3=Yes (public;published)</td>\n</tr>\n<tr>\n<td>Other Metadata</td>\n<td></td>\n</tr>\n</tbody>\n</table>\n<h2 id=\"interoperability\">Interoperability<a class=\"headerlink\" href=\"#interoperability\" title=\"Permanent link\">&para;</a></h2>\n<h3 id=\"interoperability-framework-exists\">Interoperability framework exists<a class=\"headerlink\" href=\"#interoperability-framework-exists\" title=\"Permanent link\">&para;</a></h3>\n<table>\n<thead>\n<tr>\n<th>Field</th>\n<th>Value</th>\n</tr>\n</thead>\n<tbody>\n<tr>\n<td>Chapter</td>\n<td>GovTech Maturity</td>\n</tr>\n<tr>\n<td>Variable Id</td>\n<td>govtech-interop-3</td>\n</tr>\n<tr>\n<td>Definition</td>\n<td>Is there a government interoperability framework?</td>\n</tr>\n<tr>\n<td>Format</td>\n<td>0=Unknown/n.a;1=No;2=In draft / Planned;3=Yes</td>\n</tr>\n<tr>\n<td>Other Metadata</td>\n<td>European Interoperability Framework (EIF) or similar country specific frameworks</td>\n</tr>\n</tbody>\n</table>\n<h3 id=\"interoperability-status\">Interoperability status<a class=\"headerlink\" href=\"#interoperability-status\" title=\"Permanent link\">&para;</a></h3>\n<table>\n<thead>\n<tr>\n<th>Field</th>\n<th>Value</th>\n</tr>\n</thead>\n<tbody>\n<tr>\n<td>Chapter</td>\n<td>GovTech Maturity</td>\n</tr>\n<tr>\n<td>Variable Id</td>\n<td>govtech-interop-3.4</td>\n</tr>\n<tr>\n<td>Definition</td>\n<td>GIF operational status</td>\n</tr>\n<tr>\n<td>Format</td>\n<td>0=Unkown/n.a.;1=Partially used;2=Extensively used</td>\n</tr>\n<tr>\n<td>Other Metadata</td>\n<td></td>\n</tr>\n</tbody>\n</table>\n<h3 id=\"data-quality\">Data quality<a class=\"headerlink\" href=\"#data-quality\" title=\"Permanent link\">&para;</a></h3>\n<table>\n<thead>\n<tr>\n<th>Field</th>\n<th>Value</th>\n</tr>\n</thead>\n<tbody>\n<tr>\n<td>Chapter</td>\n<td>GovTech Maturity</td>\n</tr>\n<tr>\n<td>Variable Id</td>\n<td>govtech-interop-3.6</td>\n</tr>\n<tr>\n<td>Definition</td>\n<td>Is there a data quality framework?</td>\n</tr>\n<tr>\n<td>Format</td>\n<td>0=Unknown/n.a;1=No;2=Yes</td>\n</tr>\n<tr>\n<td>Other Metadata</td>\n<td>Data quality framework for ensuring that Government data is standardised, not fragmented, and not duplicated.</td>\n</tr>\n</tbody>\n</table>\n<h3 id=\"uptime-monitoring\">Uptime monitoring<a class=\"headerlink\" href=\"#uptime-monitoring\" title=\"Permanent link\">&para;</a></h3>\n<table>\n<thead>\n<tr>\n<th>Field</th>\n<th>Value</th>\n</tr>\n</thead>\n<tbody>\n<tr>\n<td>Chapter</td>\n<td>GovTech Maturity</td>\n</tr>\n<tr>\n<td>Variable Id</td>\n<td>govtech-interop-3.7</td>\n</tr>\n<tr>\n<td>Definition</td>\n<td>Is there a system to monitor the 'uptime' of government information systems?</td>\n</tr>\n<tr>\n<td>Format</td>\n<td>0=Unknown/n.a;1=No;2=Yes</td>\n</tr>\n<tr>\n<td>Other Metadata</td>\n<td></td>\n</tr>\n</tbody>\n</table>\n<h3 id=\"replacing-legacy-systems\">Replacing legacy systems<a class=\"headerlink\" href=\"#replacing-legacy-systems\" title=\"Permanent link\">&para;</a></h3>\n<table>\n<thead>\n<tr>\n<th>Field</th>\n<th>Value</th>\n</tr>\n</thead>\n<tbody>\n<tr>\n<td>Chapter</td>\n<td>GovTech Maturity</td>\n</tr>\n<tr>\n<td>Variable Id</td>\n<td>govtech-interop-3.8</td>\n</tr>\n<tr>\n<td>Definition</td>\n<td>Is there guidance for replacing legacy government information systems?</td>\n</tr>\n<tr>\n<td>Format</td>\n<td>0=Unknown/n.a;1=No;2=Yes</td>\n</tr>\n<tr>\n<td>Other Metadata</td>\n<td></td>\n</tr>\n</tbody>\n</table>\n<h3 id=\"transparency_1\">Transparency<a class=\"headerlink\" href=\"#transparency_1\" title=\"Permanent link\">&para;</a></h3>\n<table>\n<thead>\n<tr>\n<th>Field</th>\n<th>Value</th>\n</tr>\n</thead>\n<tbody>\n<tr>\n<td>Chapter</td>\n<td>GovTech Maturity</td>\n</tr>\n<tr>\n<td>Variable Id</td>\n<td>govtech-interop-3.9</td>\n</tr>\n<tr>\n<td>Definition</td>\n<td>Monitoring \\&amp; publishing of GIF usage, compliance, benefits?</td>\n</tr>\n<tr>\n<td>Format</td>\n<td>0=Unknown/n.a;1=No;2=Yes (internal;not published); 3=Yes (public;published)</td>\n</tr>\n<tr>\n<td>Other Metadata</td>\n<td></td>\n</tr>\n</tbody>\n</table>\n<h2 id=\"financial-management\">Financial Management<a class=\"headerlink\" href=\"#financial-management\" title=\"Permanent link\">&para;</a></h2>\n<h3 id=\"ifmis-exists\">IFMIS exists<a class=\"headerlink\" href=\"#ifmis-exists\" title=\"Permanent link\">&para;</a></h3>\n<table>\n<thead>\n<tr>\n<th>Field</th>\n<th>Value</th>\n</tr>\n</thead>\n<tbody>\n<tr>\n<td>Chapter</td>\n<td>GovTech Maturity</td>\n</tr>\n<tr>\n<td>Variable Id</td>\n<td>govtech-financial-5</td>\n</tr>\n<tr>\n<td>Definition</td>\n<td>Is there an operational FMIS in place to support core PFM functions?</td>\n</tr>\n<tr>\n<td>Format</td>\n<td>0=Unkown/n.a.;1=Implementation in progress;2=Yes (in use)</td>\n</tr>\n<tr>\n<td>Other Metadata</td>\n<td></td>\n</tr>\n</tbody>\n</table>\n<h3 id=\"ifmis-functionality\">IFMIS functionality<a class=\"headerlink\" href=\"#ifmis-functionality\" title=\"Permanent link\">&para;</a></h3>\n<table>\n<thead>\n<tr>\n<th>Field</th>\n<th>Value</th>\n</tr>\n</thead>\n<tbody>\n<tr>\n<td>Chapter</td>\n<td>GovTech Maturity</td>\n</tr>\n<tr>\n<td>Variable Id</td>\n<td>govtech-financial-5.6</td>\n</tr>\n<tr>\n<td>Definition</td>\n<td>FMIS functional capabilities</td>\n</tr>\n<tr>\n<td>Format</td>\n<td>0=Unkown/n.a.;1=Treasury (execution);2=T + Budget (preparation);3=T + B + Other</td>\n</tr>\n<tr>\n<td>Other Metadata</td>\n<td></td>\n</tr>\n</tbody>\n</table>\n<h3 id=\"scope\">Scope<a class=\"headerlink\" href=\"#scope\" title=\"Permanent link\">&para;</a></h3>\n<table>\n<thead>\n<tr>\n<th>Field</th>\n<th>Value</th>\n</tr>\n</thead>\n<tbody>\n<tr>\n<td>Chapter</td>\n<td>GovTech Maturity</td>\n</tr>\n<tr>\n<td>Variable Id</td>\n<td>govtech-financial-5.7</td>\n</tr>\n<tr>\n<td>Definition</td>\n<td>Scope of FMIS (coverage of budgets)</td>\n</tr>\n<tr>\n<td>Format</td>\n<td>0=Unkown/n.a.;1=Central gov;2=Central + Local gov</td>\n</tr>\n<tr>\n<td>Other Metadata</td>\n<td></td>\n</tr>\n</tbody>\n</table>\n<h3 id=\"software\">Software<a class=\"headerlink\" href=\"#software\" title=\"Permanent link\">&para;</a></h3>\n<table>\n<thead>\n<tr>\n<th>Field</th>\n<th>Value</th>\n</tr>\n</thead>\n<tbody>\n<tr>\n<td>Chapter</td>\n<td>GovTech Maturity</td>\n</tr>\n<tr>\n<td>Variable Id</td>\n<td>govtech-financial-5.8</td>\n</tr>\n<tr>\n<td>Definition</td>\n<td>Type of FMIS software</td>\n</tr>\n<tr>\n<td>Format</td>\n<td>0=Unkown/n.a.;1=Custom Software;2=Commercial/COTS Software;3=Hybrid (Custom + COTS)</td>\n</tr>\n<tr>\n<td>Other Metadata</td>\n<td></td>\n</tr>\n</tbody>\n</table>\n<h3 id=\"chart-of-accounts\">Chart of Accounts<a class=\"headerlink\" href=\"#chart-of-accounts\" title=\"Permanent link\">&para;</a></h3>\n<table>\n<thead>\n<tr>\n<th>Field</th>\n<th>Value</th>\n</tr>\n</thead>\n<tbody>\n<tr>\n<td>Chapter</td>\n<td>GovTech Maturity</td>\n</tr>\n<tr>\n<td>Variable Id</td>\n<td>govtech-financial-5.10</td>\n</tr>\n<tr>\n<td>Definition</td>\n<td>Is there a unified budget classification/chart of accounts?</td>\n</tr>\n<tr>\n<td>Format</td>\n<td>0=Unknown/n.a;1=No;2=Yes (Central government only);3=Yes (Both central and sub-national government)</td>\n</tr>\n<tr>\n<td>Other Metadata</td>\n<td>Unified budget classification (BC) / chart of accounts (CoA) to record/report all budget revenues, expenses and other transactions?</td>\n</tr>\n</tbody>\n</table>\n<h3 id=\"sdg-monitoring\">SDG monitoring<a class=\"headerlink\" href=\"#sdg-monitoring\" title=\"Permanent link\">&para;</a></h3>\n<table>\n<thead>\n<tr>\n<th>Field</th>\n<th>Value</th>\n</tr>\n</thead>\n<tbody>\n<tr>\n<td>Chapter</td>\n<td>GovTech Maturity</td>\n</tr>\n<tr>\n<td>Variable Id</td>\n<td>govtech-financial-5.11</td>\n</tr>\n<tr>\n<td>Definition</td>\n<td>Does FMIS capture expenses linked to the SDGs and other strategic goals?</td>\n</tr>\n<tr>\n<td>Format</td>\n<td>0=Unknown/n.a;1=No;2=Partially;3=Extensively</td>\n</tr>\n<tr>\n<td>Other Metadata</td>\n<td>Budget expenses linked to the Sustainable Development Goals (SDGs) using gender, climate change and other tags.</td>\n</tr>\n</tbody>\n</table>\n<h3 id=\"programme-monitoring\">Programme monitoring<a class=\"headerlink\" href=\"#programme-monitoring\" title=\"Permanent link\">&para;</a></h3>\n<table>\n<thead>\n<tr>\n<th>Field</th>\n<th>Value</th>\n</tr>\n</thead>\n<tbody>\n<tr>\n<td>Chapter</td>\n<td>GovTech Maturity</td>\n</tr>\n<tr>\n<td>Variable Id</td>\n<td>govtech-financial-5.12</td>\n</tr>\n<tr>\n<td>Definition</td>\n<td>Does FMIS capture non-financial data (KPIs) on programs/projects?</td>\n</tr>\n<tr>\n<td>Format</td>\n<td>0=Unknown/n.a;1=No;2=Partially (Some of the KPIs for selected programs);3=Extensively (KPIs captured for most of the programs)</td>\n</tr>\n<tr>\n<td>Other Metadata</td>\n<td>Non-financial data or Key Performance Indicators (KPIs) related to the programs/projects/activities.</td>\n</tr>\n</tbody>\n</table>\n<h3 id=\"interoperability_1\">Interoperability<a class=\"headerlink\" href=\"#interoperability_1\" title=\"Permanent link\">&para;</a></h3>\n<table>\n<thead>\n<tr>\n<th>Field</th>\n<th>Value</th>\n</tr>\n</thead>\n<tbody>\n<tr>\n<td>Chapter</td>\n<td>GovTech Maturity</td>\n</tr>\n<tr>\n<td>Variable Id</td>\n<td>govtech-financial-5.13</td>\n</tr>\n<tr>\n<td>Definition</td>\n<td>Does FMIS exchange data with other systems?</td>\n</tr>\n<tr>\n<td>Format</td>\n<td>0=Unknown/n.a;1=No;2=Yes (via separate interfaces) 3=Yes (via Government Service Bus)</td>\n</tr>\n<tr>\n<td>Other Metadata</td>\n<td>To select I-5.13= 2, I-4 should be 2 (GSB in use)</td>\n</tr>\n</tbody>\n</table>\n<h3 id=\"governance\">Governance<a class=\"headerlink\" href=\"#governance\" title=\"Permanent link\">&para;</a></h3>\n<table>\n<thead>\n<tr>\n<th>Field</th>\n<th>Value</th>\n</tr>\n</thead>\n<tbody>\n<tr>\n<td>Chapter</td>\n<td>GovTech Maturity</td>\n</tr>\n<tr>\n<td>Variable Id</td>\n<td>govtech-financial-5.14</td>\n</tr>\n<tr>\n<td>Definition</td>\n<td>Governance of FMIS operations (compliance, security, audit trails, etc.)?</td>\n</tr>\n<tr>\n<td>Format</td>\n<td>0=Unknown/n.a;1=No;2=Yes (internal;not published); 3=Yes (public;published)</td>\n</tr>\n<tr>\n<td>Other Metadata</td>\n<td></td>\n</tr>\n</tbody>\n</table>\n<h2 id=\"treasury-single-account\">Treasury Single Account<a class=\"headerlink\" href=\"#treasury-single-account\" title=\"Permanent link\">&para;</a></h2>\n<h3 id=\"automated-payments\">Automated payments<a class=\"headerlink\" href=\"#automated-payments\" title=\"Permanent link\">&para;</a></h3>\n<table>\n<thead>\n<tr>\n<th>Field</th>\n<th>Value</th>\n</tr>\n</thead>\n<tbody>\n<tr>\n<td>Chapter</td>\n<td>GovTech Maturity</td>\n</tr>\n<tr>\n<td>Variable Id</td>\n<td>govtech-treasury-6</td>\n</tr>\n<tr>\n<td>Definition</td>\n<td>Is there a TSA supported by FMIS to automate payments and bank reconciliation?</td>\n</tr>\n<tr>\n<td>Format</td>\n<td>0=Unknown/n.a;1=No;2=Implementation in progress;3=Yes (in use)</td>\n</tr>\n<tr>\n<td>Other Metadata</td>\n<td></td>\n</tr>\n</tbody>\n</table>\n<h3 id=\"scope_1\">Scope<a class=\"headerlink\" href=\"#scope_1\" title=\"Permanent link\">&para;</a></h3>\n<table>\n<thead>\n<tr>\n<th>Field</th>\n<th>Value</th>\n</tr>\n</thead>\n<tbody>\n<tr>\n<td>Chapter</td>\n<td>GovTech Maturity</td>\n</tr>\n<tr>\n<td>Variable Id</td>\n<td>govtech-treasury-6.5</td>\n</tr>\n<tr>\n<td>Definition</td>\n<td>Scope of TSA operations</td>\n</tr>\n<tr>\n<td>Format</td>\n<td>0=Unkown/n.a.;1=Partially used by the MDAs;2=Extensively used by all MDAs</td>\n</tr>\n<tr>\n<td>Other Metadata</td>\n<td>MDAs: Ministries, Departments, Agencies</td>\n</tr>\n</tbody>\n</table>\n<h3 id=\"payment-system\">Payment system<a class=\"headerlink\" href=\"#payment-system\" title=\"Permanent link\">&para;</a></h3>\n<table>\n<thead>\n<tr>\n<th>Field</th>\n<th>Value</th>\n</tr>\n</thead>\n<tbody>\n<tr>\n<td>Chapter</td>\n<td>GovTech Maturity</td>\n</tr>\n<tr>\n<td>Variable Id</td>\n<td>govtech-treasury-6.6</td>\n</tr>\n<tr>\n<td>Definition</td>\n<td>Type of electronic payment systems in place</td>\n</tr>\n<tr>\n<td>Format</td>\n<td>0=Unkown/n.a.;1=RTGS (Real-Time Gross Settlement);2=FPS / ACH (Fast Payment System / Automated Clearinghouse System);3=Both RTGS \\&amp; FPS/ACH</td>\n</tr>\n<tr>\n<td>Other Metadata</td>\n<td>RTGS: Real Time Gross Settlements, ACH: Automated Clearing House</td>\n</tr>\n</tbody>\n</table>\n<h3 id=\"central-bank-interface\">Central Bank interface<a class=\"headerlink\" href=\"#central-bank-interface\" title=\"Permanent link\">&para;</a></h3>\n<table>\n<thead>\n<tr>\n<th>Field</th>\n<th>Value</th>\n</tr>\n</thead>\n<tbody>\n<tr>\n<td>Chapter</td>\n<td>GovTech Maturity</td>\n</tr>\n<tr>\n<td>Variable Id</td>\n<td>govtech-treasury-6.7</td>\n</tr>\n<tr>\n<td>Definition</td>\n<td>Is there a TSA interface linking FMIS with the Central Bank systems?</td>\n</tr>\n<tr>\n<td>Format</td>\n<td>0=Unknown/n.a;1=No;2=Implementation in progress;3=Yes (in use)</td>\n</tr>\n<tr>\n<td>Other Metadata</td>\n<td>To select I-6.7= 2, I-4 should be 2 (GSB in use)</td>\n</tr>\n</tbody>\n</table>\n<h3 id=\"governance_1\">Governance<a class=\"headerlink\" href=\"#governance_1\" title=\"Permanent link\">&para;</a></h3>\n<table>\n<thead>\n<tr>\n<th>Field</th>\n<th>Value</th>\n</tr>\n</thead>\n<tbody>\n<tr>\n<td>Chapter</td>\n<td>GovTech Maturity</td>\n</tr>\n<tr>\n<td>Variable Id</td>\n<td>govtech-treasury-6.8</td>\n</tr>\n<tr>\n<td>Definition</td>\n<td>Governance of TSA operations (compliance, security, audit trails, etc.)?</td>\n</tr>\n<tr>\n<td>Format</td>\n<td>0=Unknown/n.a;1=No;2=Yes (internal;not publ