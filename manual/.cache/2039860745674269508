      {
        "location": "mobile-communications",
        "level": 3,
        "title": "Mobile Communications",
        "text": "Field Value Variable Id iiag-infrastructure-mobcomm Definition Measures the number of subscriptions to a public mobile-telephone service that provide access to the public switched telephone network (PSTN) using cellular technology. It includes the number of postpaid subscriptions and the number of active prepaid accounts, divided by population and multiplied by 100. Format 0=Unknown or n.a.; 1=&lt;20%; 2=20-49%; 3=50-69%; 4=70-89%; 5=&gt;89% Other Metadata IIAG Series Id - MobComm. Original data source/s - ITU",
        "path": [],
