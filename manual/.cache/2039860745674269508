      {
        "location": "access-to-healthcare",
        "level": 3,
        "title": "Access to Healthcare",
        "text": "Field Value Variable Id iiag-health-acchealth Definition Estimates how much households in each country are spending on health directly out of pocket. It Estimates the share of out of pocket payment of total current health expenditures. Format 0=Unknown or n.a.; 1=&lt;20%; 2=20-49%; 3=50-69%; 4=70-89%; 5=&gt;89% Other Metadata IIAG Series Id - AccHealth. Original data source/s - V-DEM/WHO",
        "path": [],
        "tags": []
      },
      {
        "location": "access-to-water-sanitation",
        "level": 3,
        "title": "Access to Water \\&amp; Sanitation",
        "text": "Field Value Variable Id iiag-health-accwatersanit Definition Measures the availability of drinking water from an improved source, provided collection time is not more than 30 minutes for a round trip, including queuing. Format 0=Unknown or n.a.; 1=&lt;20%; 2=20-49%; 3=50-69%; 4=70-89%; 5=&gt;89% Other Metadata IIAG Series Id - AccWaterSanit. Original data source/s - WHO\\&amp;UNICEF",
        "path": [],
        "tags": []
      },
      {
        "location": "control-of-communicable-diseases",
        "level": 3,
        "title": "Control of Communicable Diseases",
        "text": "Field Value Variable Id iiag-health-contcomdis Definition Measures the estimated number of deaths from malaria in a given year, calculated by MIF per 100,000 of the population using the World Population Prospects by UNDESA. Format 0=Unknown or n.a.; 1=&lt;20%; 2=20-49%; 3=50-69%; 4=70-89%; 5=&gt;89% Other Metadata IIAG Series Id - ContComDis. Original data source/s - UNAIDS/WHO",
        "path": [],
        "tags": []
      },
      {
        "location": "control-of-non-communicable-diseases",
        "level": 3,
        "title": "Control of Non-Communicable Diseases",
        "text": "Field Value Variable Id iiag-health-contnoncomdis Definition Measures the age-standardised percentage of DALY's (disability adjusted life years) due to metabolic risks. Disability-Adjusted Life Years (DALYs) are defined as the sum of years lost due to premature death and years lived with disability. DALYs are also defined as years of healthy life lost. Format 0=Unknown or n.a.; 1=&lt;20%; 2=20-49%; 3=50-69%; 4=70-89%; 5=&gt;89% Other Metadata IIAG Series Id - ContNonComDis. Original data source/s - IHME",
        "path": [],
        "tags": []
      },
      {
        "location": "child-maternal-health",
        "level": 3,
        "title": "Child \\&amp; Maternal Health",
        "text": "Field Value Variable Id iiag-health-contchildmathealth Definition Measures the probability of dying between birth and exact age 5, expressed per 1,000 live births. Format 0=Unknown or n.a.; 1=&lt;20%; 2=20-49%; 3=50-69%; 4=70-89%; 5=&gt;89% Other Metadata IIAG Series Id - ContChildMatHealth. Original data source/s - UN IGME/UN MMEIG/UNDESA/UNICEF\\&amp;WHO\\&amp;WB",
        "path": [],
        "tags": []
      },
      {
        "location": "health-quality",
        "level": 3,
        "title": "Health Quality",
        "text": "Field Value Variable Id iiag-health-healthqual Definition Measures compliance with 1 out of 15 WHO International Health Regulations core capacity scores: Human resources. The revised International Health Regulations (IHR) were adopted in 2005 and entered into force in 2007. Under the IHR, States Parties are obliged to develop and maintain minimum core capacities for surveillance and response, including at points of entry, in order to early detect, assess, notify, and respond to any potential public health events of international concern. The 15 capacities are: C1. Policy, legal and normative instruments to implement IHR, C2. IHR coordination and National IHR Focal Point, C.3. Financing, C4. Laboratory, C5. Surveillance, C6. Human resources, C7. Health emergency management, C8. Health services provision, C9. Infection prevention and control (IPC) C10. Risk communication and community engagement (RCCE), C11. Points of entry (PoEs) and border health, C12. Zoonotic diseases, C13. Food safety, C14. Chemical events, C15. Radiation emergencies. Format 0=Unknown or n.a.; 1=&lt;20%; 2=20-49%; 3=50-69%; 4=70-89%; 5=&gt;89% Other Metadata IIAG Series Id - HealthQual. Original data source/s - WHO",
        "path": [],
        "tags": []
      },
      {
        "location": "public-perception-of-health-provision",
        "level": 3,
        "title": "Public Perception of Health Provision",
        "text": "Field Value Variable Id iiag-health-sathealth Definition Assesses citizens' perceptions of how easy it is to obtain the medical care they need. Format 0=Unknown or n.a.; 1=&lt;20%; 2=20-49%; 3=50-69%; 4=70-89%; 5=&gt;89% Other Metadata IIAG Series Id - SatHealth. Original data source/s - AFR",
        "path": [],
        "tags": []
      },
      {
        "location": "education",
        "level": 2,
        "title": "Education",
        "text": "",
        "path": [],
        "tags": []
      },
      {
        "location": "equality-in-education",
        "level": 3,
        "title": "Equality in Education",
        "text": "Field Value Variable Id iiag-education-equeduc Definition Measures the ratio of female gross enrolment to male gross enrolment in primary and lower secondary education. Format 0=Unknown or n.a.; 1=&lt;20%; 2=20-49%; 3=50-69%; 4=70-89%; 5=&gt;89% Other Metadata IIAG Series Id - EquEduc. Original data source/s - V-DEM/UNESCO",
        "path": [],
        "tags": []
      },
      {
        "location": "education-enrolment",
        "level": 3,
        "title": "Education Enrolment",
        "text": "Field Value Variable Id iiag-education-educenr Definition Measures the number of students enrolled in pre-primary level of education, regardless of age, expressed as a percentage of the eligible official school-age population corresponding to pre-primary education. Format 0=Unknown or n.a.; 1=&lt;20%; 2=20-49%; 3=50-69%; 4=70-89%; 5=&gt;89% Other Metadata IIAG Series Id - EducEnr. Original data source/s - UNESCO",
        "path": [],
        "tags": []
      },
      {
        "location": "education-completion",
        "level": 3,
        "title": "Education Completion",
        "text": "Field Value Variable Id iiag-education-compeduc Definition Measures the percentage of a cohort of children or young people aged 3-5 years above the intended age for the last grade of the primary level of education who have completed that grade. Format 0=Unknown or n.a.; 1=&lt;20%; 2=20-49%; 3=50-69%; 4=70-89%; 5=&gt;89% Other Metadata IIAG Series Id - CompEduc. Original data source/s - UNESCO",
        "path": [],
        "tags": []
      },
      {
        "location": "human-resources-in-education",
        "level": 3,
        "title": "Human Resources in Education",
        "text": "Field Value Variable Id iiag-education-educres Definition Measures the average number of pupils per qualified teacher at the primary level of education in a given academic year. A qualified teacher is one who has at least the minimum academic qualifications required for teaching their subjects at the relevant level in a given country in a given academic year. The higher the pupil/qualified teacher ratio, the lower the relative access of pupils to qualified teachers. Format 0=Unknown or n.a.; 1=&lt;20%; 2=20-49%; 3=50-69%; 4=70-89%; 5=&gt;89% Other Metadata IIAG Series Id - EducRes. Original data source/s - UNESCO",
        "path": [],
        "tags": []
      },
      {
        "location": "education-quality",
        "level": 3,
        "title": "Education Quality",
        "text": "Field Value Variable Id iiag-education-eduqqual Definition Assesses the extent to which there are solid institutions for basic, secondary, and tertiary education, as well as for research and development. It Assesses whether education policy is successful in delivering high quality education and training, and research and development receive effective support from the government. It does not focus on expenditures alone, but also on the quality and competitiveness of the education system and the research sector, considering the structure of funding and knowledge providers (public, private and international cooperation), the output of the educational and developmental efforts, e.g. enrolment rates, literacy rates, percentage of people with higher education and number of patent applications. Format 0=Unknown or n.a.; 1=&lt;20%; 2=20-49%; 3=50-69%; 4=70-89%; 5=&gt;89% Other Metadata IIAG Series Id - EduqQual. Original data source/s - BS/WB/WEF",
        "path": [],
        "tags": []
      },
      {
        "location": "public-perception-of-education-provision",
        "level": 3,
        "title": "Public Perception of Education Provision",
        "text": "Field Value Variable Id iiag-education-sateduc Definition Assesses citizens' perceptions of how easy it was to obtain the services they needed from teachers or school officials. Format 0=Unknown or n.a.; 1=&lt;20%; 2=20-49%; 3=50-69%; 4=70-89%; 5=&gt;89% Other Metadata IIAG Series Id - SatEduc. Original data source/s - AFR",
        "path": [],
        "tags": []
      },
      {
        "location": "social-protection-welfare",
        "level": 2,
        "title": "Social Protection \\&amp; Welfare",
        "text": "",
        "path": [],
        "tags": []
      },
      {
        "location": "social-safety-nets",
        "level": 3,
        "title": "Social Safety Nets",
        "text": "Field Value Variable Id iiag-social-socialsafnet Definition Assesses the extent to which there are departments or equivalent mandated to ensure social safety nets for the elderly, those with an illness or health conditions and the unemployed. Format 0=Unknown or n.a.; 1=&lt;20%; 2=20-49%; 3=50-69%; 4=70-89%; 5=&gt;89% Other Metadata IIAG Series Id - SocialSafNet. Original data source/s - AFIDEP/BS",
        "path": [],
        "tags": []
      },
      {
        "location": "poverty-reduction-policies",
        "level": 3,
        "title": "Poverty Reduction Policies",
        "text": "Field Value Variable Id iiag-social-povredpol Definition Assesses the extent to which significant parts of the population are fundamentally excluded from society due to poverty and inequality. It Assesses the level of social exclusion as a determining factor for economic transformation. It refers to structural exclusion and not to the output strength of a country’s economy as reflected in macroeconomic data like unemployment or GDP growth. Format 0=Unknown or n.a.; 1=&lt;20%; 2=20-49%; 3=50-69%; 4=70-89%; 5=&gt;89% Other Metadata IIAG Series Id - PovRedPol. Original data source/s - AfDB/BS/WB",
        "path": [],
        "tags": []
      },
      {
        "location": "socioeconomic-inequality-mitigation",
        "level": 3,
        "title": "Socioeconomic Inequality Mitigation",
        "text": "Field Value Variable Id iiag-social-ineqmitig Definition Assesses the extent to which the pattern of public expenditures and revenue collection affects the poor and is consistent with national poverty reduction priorities. Format 0=Unknown or n.a.; 1=&lt;20%; 2=20-49%; 3=50-69%; 4=70-89%; 5=&gt;89% Other Metadata IIAG Series Id - IneqMitig. Original data source/s - AfDB/FFP/WB/WID.World",
        "path": [],
        "tags": []
      },
      {
        "location": "decent-housing",
        "level": 3,
        "title": "Decent Housing",
        "text": "Field Value Variable Id iiag-social-dechous Definition Measures the proportion of the urban population living in slums. Slum households are households whose members suffer one or more of the following ‘household deprivations’: i) Lack of access to improved water source, ii) Lack of access to improved sanitation facilities, iii) Lack of sufficient living area, iv)Lack of housing durability and, v) Lack of security of tenure. Estimations do not include security of tenure due to data limitations. Format 0=Unknown or n.a.; 1=&lt;20%; 2=20-49%; 3=50-69%; 4=70-89%; 5=&gt;89% Other Metadata IIAG Series Id - DecHous. Original data source/s - CAHF/UN-Habitat",
        "path": [],
        "tags": []
      },
      {
        "location": "food-security",
        "level": 3,
        "title": "Food Security",
        "text": "Field Value Variable Id iiag-social-foodsec Definition Measures the prevalence of undernourishment, expressed as the probability that a randomly selected individual from the population consumes an amount of calories that is insufficient to cover her/his energy requirement for an active and healthy life. Format 0=Unknown or n.a.; 1=&lt;20%; 2=20-49%; 3=50-69%; 4=70-89%; 5=&gt;89% Other Metadata IIAG Series Id - FoodSec. Original data source/s - FAO",
        "path": [],
        "tags": []
      },
      {
        "location": "public-perception-of-social-protection-lived-poverty",
        "level": 3,
        "title": "Public Perception of Social Protection \\&amp; Lived Poverty",
        "text": "Field Value Variable Id iiag-social-livpovpubpercsocprot Definition Assesses citizens' perceptions of their present living conditions. Format 0=Unknown or n.a.; 1=&lt;20%; 2=20-49%; 3=50-69%; 4=70-89%; 5=&gt;89% Other Metadata IIAG Series Id - LivPovPubPercSocProt. Original data source/s - AFR",
        "path": [],
        "tags": []
      },
      {
        "location": "sustainable-environment",
        "level": 2,
        "title": "Sustainable Environment",
        "text": "",
        "path": [],
        "tags": []
      },
      {
        "location": "promotion-of-environmental-sustainability",
        "level": 3,
        "title": "Promotion of Environmental Sustainability",
        "text": "Field Value Variable Id iiag-environ-promenvsust Definition Assesses the extent to which environmental concerns are effectively taken into account in both macro and microeconomic terms. It considers the extent to which externalisation of costs or inadequate time horizons are avoided or restrained by environmental regulation. In macroeconomic terms, it Assesses the extent to which tax and energy policies take ecological goals and Measures into account (e.g. promotion of renewable energies, CO2 reduction goals). In microeconomic terms, it Assesses the extent to which the government sets incentives for environmentally sound consumption and investments to households and companies. A deeply ingrained awareness of the environment or nature in society may serve as a functional equivalent. Format 0=Unknown or n.a.; 1=&lt;20%; 2=20-49%; 3=50-69%; 4=70-89%; 5=&gt;89% Other Metadata IIAG Series Id - PromEnvSust. Original data source/s - AfDB/BS/WB",
        "path": [],
        "tags": []
      },
      {
        "location": "enforcement-of-environmental-policies",
        "level": 3,
        "title": "Enforcement of Environmental Policies",
        "text": "Field Value Variable Id iiag-environ-enfenvpol Definition Assesses the extent to which environmental protection authorities enforce environmental laws. This is based on the following criteria: the extent to which companies comply with the law after notification of violations from environmental protection authorities; firms get audited or inspected by environmental protection authorities as a result of allegations of pollution by neighbours; firms are routinely audited by the environmental protection authorities; it is likely that environmental protection authorities will impose sanctions if violations are detected. Format 0=Unknown or n.a.; 1=&lt;20%; 2=20-49%; 3=50-69%; 4=70-89%; 5=&gt;89% Other Metadata IIAG Series Id - EnfEnvPol. Original data source/s - WEF/WJP",
        "path": [],
        "tags": []
      },
      {
        "location": "air-quality",
        "level": 3,
        "title": "Air Quality",
        "text": "Field Value Variable Id iiag-environ-airqual Definition Measures the ratio of disability-adjusted life-years (DALYs) to the population per 100,000 people due to air pollution. Format 0=Unknown or n.a.; 1=&lt;20%; 2=20-49%; 3=50-69%; 4=70-89%; 5=&gt;89% Other Metadata IIAG Series Id - AirQual. Original data source/s - HEI\\&amp;IHME",
        "path": [],
        "tags": []
      },
      {
        "location": "sustainable-use-of-land-forests",
        "level": 3,
        "title": "Sustainable Use of Land \\&amp; Forests",
        "text": "Field Value Variable Id iiag-environ-sususelandfor Definition Measures the diversification of agricultural production as well as the extent to which the agricultural area is under certified organic agriculture. Format 0=Unknown or n.a.; 1=&lt;20%; 2=20-49%; 3=50-69%; 4=70-89%; 5=&gt;89% Other Metadata IIAG Series Id - SusUseLandFor. Original data source/s - FAO/WB/WRI",
        "path": [],
        "tags": []
      },
      {
        "location": "land-water-biodiversity-protection",
        "level": 3,
        "title": "Land \\&amp; Water Biodiversity Protection",
        "text": "Field Value Variable Id iiag-environ-landwatbiodiv Definition Assesses a country’s efforts to achieve 30% protection for all biomes within its borders. It is calculated using the percentage of each country’s biomes covered by protected areas. It is calculated using the proportions of the area of each of a country’s biome types that are covered by protected areas and then constructing a weighted sum of the protection percentages for all biomes within that country. Protection percentages are weighted according to the prevalence of each biome type within that country. Format 0=Unknown or n.a.; 1=&lt;20%; 2=20-49%; 3=50-69%; 4=70-89%; 5=&gt;89% Other Metadata IIAG Series Id - LandWatBiodiv. Original data source/s - ENACT/WB/Yale\\&amp;Columbia",
        "path": [],
        "tags": []
      }
    ],
