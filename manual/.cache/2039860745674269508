      {
        "location": "rural-land-water-access",
        "level": 3,
        "title": "Rural Land \\&amp; Water Access",
        "text": "Field Value Variable Id iiag-rural-rurlandwatacc Definition Assesses the extent to which access to land is afforded to rural people via the policy framework, which is key to their capacity to undergo rural transformation. Format 0=Unknown or n.a.; 1=&lt;20%; 2=20-49%; 3=50-69%; 4=70-89%; 5=&gt;89% Other Metadata IIAG Series Id - RurLandWatAcc. Original data source/s - IFAD",
        "path": [],
