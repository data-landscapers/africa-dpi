      },
      {
        "location": "rural-market-access",
        "level": 3,
        "title": "Rural Market Access",
        "text": "Field Value Variable Id iiag-rural-rurmarkaccifad Definition Assesses the extent to which existing agricultural input markets and produce markets are reliably providing value for money to smallholders for inputs and the highest proportion of the retail price for produce. Format 0=Unknown or n.a.; 1=&lt;20%; 2=20-49%; 3=50-69%; 4=70-89%; 5=&gt;89% Other Metadata IIAG Series Id - RurMarkAccIFAD. Original data source/s - IFAD",
        "path": [],
        "tags": []
      },
      {
        "location": "rural-economy-support",
        "level": 3,
        "title": "Rural Economy Support",
        "text": "Field Value Variable Id iiag-rural-rurecosupp Definition Assesses the extent to which government prioritises strategies for and investment in the rural poor and is actively promoting the development of a robust private sector in rural areas. Format 0=Unknown or n.a.; 1=&lt;20%; 2=20-49%; 3=50-69%; 4=70-89%; 5=&gt;89% Other Metadata IIAG Series Id - RurEcoSupp. Original data source/s - IFAD",
        "path": [],
        "tags": []
      },
      {
        "location": "rural-representation-participation",
        "level": 3,
        "title": "Rural Representation \\&amp; Participation",
        "text": "Field Value Variable Id iiag-rural-rurreppart Definition Assesses the extent to which rural people can organize into autonomous groups. Format 0=Unknown or n.a.; 1=&lt;20%; 2=20-49%; 3=50-69%; 4=70-89%; 5=&gt;89% Other Metadata IIAG Series Id - RurRepPart. Original data source/s - IFAD",
        "path": [],
