      },
      {
        "location": "internet-computers",
        "level": 3,
        "title": "Internet \\&amp; Computers",
        "text": "Field Value Variable Id iiag-infrastructure-digacc Definition Measures the proportion of households that have a computer. A computer refers to a desktop computer, a laptop (portable) computer or a tablet (or similar handheld computer). Format 0=Unknown or n.a.; 1=&lt;20%; 2=20-49%; 3=50-69%; 4=70-89%; 5=&gt;89% Other Metadata IIAG Series Id - DigAcc. Original data source/s - ITU/Cable/WB",
        "path": [],
